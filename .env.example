# Required: Google Gemini API key
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model configuration (change here without touching code)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional: LangSmith tracing (recommended for evaluation evidence)
# Sign up at https://smith.langchain.com and create a project
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=incident-rag-assistant
